/ {
 model = "NXP Freedom KL25Z board";
 compatible = "nxp,frdm-kl25z", "nxp,kl25z", "nxp,mkl25z4";
 aliases {
  led0 = &green_led;
  led1 = &blue_led;
  led2 = &red_led;
  sw0 = &user_button_0;
  sw1 = &user_button_1;
 };
 chosen {
  zephyr,sram = &sram0;
  zephyr,flash = &flash0;
  zephyr,console = &uart0;
  zephyr,shell-uart = &uart0;
 };
 leds {
  compatible = "gpio-leds";
  red_led: led_0 {
   gpios = <&gpiob 18 (1 << 0)>;
   label = "User LD1";
  };
  green_led: led_1 {
   gpios = <&gpiob 19 (1 << 0)>;
   label = "User LD2";
  };
  blue_led: led_2 {
   gpios = <&gpiod 1 (1 << 0)>;
   label = "User LD3";
  };
 };
 gpio_keys {
  compatible = "gpio-keys";
  user_button_0: button_0 {
   label = "User SW0";
   gpios = <&gpioa 16 (1 << 0)>;
  };
  user_button_1: button_1 {
   label = "User SW1";
   gpios = <&gpioa 17 (1 << 0)>;
  };
 };
 arduino_header: connector {
  compatible = "arduino-header-r3";
  #gpio-cells = <2>;
  gpio-map-mask = <0xffffffff 0xffffffc0>;
  gpio-map-pass-thru = <0 0x3f>;
  gpio-map = <0 0 &gpiob 0 0>,
      <1 0 &gpiob 1 0>,
      <2 0 &gpiob 2 0>,
      <3 0 &gpiob 3 0>,
      <4 0 &gpioc 2 0>,
      <5 0 &gpioc 1 0>,
      <6 0 &gpioa 1 0>,
      <7 0 &gpioa 2 0>,
      <8 0 &gpiod 4 0>,
      <9 0 &gpioa 12 0>,
      <10 0 &gpioa 4 0>,
      <11 0 &gpioa 5 0>,
      <12 0 &gpioc 8 0>,
      <13 0 &gpioc 9 0>,
      <14 0 &gpioa 13 0>,
      <15 0 &gpiod 5 0>,
      <16 0 &gpiod 0 0>,
      <17 0 &gpiod 2 0>,
      <18 0 &gpiod 3 0>,
      <19 0 &gpiod 1 0>,
      <20 0 &gpioe 0 0>,
      <21 0 &gpioe 1 0>;
 };
};
&sim {
 pllfll-select = <1>;
 er32k-select = <3>;
};
&cpu0 {
 clock-frequency = <48000000>;
};
&adc0 {
 status = "okay";
 pinctrl-0 = <&ADC0_SE12_PTB2>;
};
&i2c0 {
 status = "okay";
 pinctrl-0 = <&I2C0_SCL_PTE24 &I2C0_SDA_PTE25>;
 mma8451q@1d {
  compatible = "nxp,fxos8700","nxp,mma8451q";
  reg = <0x1d>;
  label = "MMA8451Q";
  int1-gpios = <&gpioa 14 (1 << 0)>;
  int2-gpios = <&gpioa 15 (1 << 0)>;
 };
};
&I2C0_SCL_PTE24 {
 bias-pull-up;
};
&I2C0_SDA_PTE25 {
 bias-pull-up;
};
&uart0 {
 status = "okay";
 current-speed = <115200>;
 pinctrl-0 = <&UART0_RX_PTA1 &UART0_TX_PTA2>;
};
&gpioa {
 status = "okay";
};
&gpiob {
 status = "okay";
};
&gpiod {
 status = "okay";
};
zephyr_udc0: &usbotg {
 compatible = "nxp,kinetis-usbd";
 status = "okay";
 num-bidir-endpoints = <8>;
};
